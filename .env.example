# Contraseña del panel de admin.
# - En tu PC (desarrollo): opcional — sin esto el panel queda abierto en localhost.
# - En producción (Vercel/Railway/etc.): OBLIGATORIA — sin esto el panel se bloquea.
ADMIN_PASSWORD=cambiame-por-una-contraseña-segura

# Base de datos Postgres. Gratis en neon.tech (ver README, sección Base de datos).
# Local con Postgres instalado en tu PC: postgres://postgres:tu-clave@localhost:5432/taply
# Neon (producción): postgres://usuario:clave@algo.neon.tech/taply?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/taply

# Número de WhatsApp de la agencia (con código de país, sin +, sin espacios)
# usado en la landing y en los botones de contacto.
NEXT_PUBLIC_WHATSAPP_NUMBER=5493513480773

# Google Places API — opcional. Sin esto, rating y reseñas se cargan a
# mano como siempre; con esto, se actualizan solos todos los días para
# cualquier cliente que tenga un Google Place ID cargado.
# Se consigue en console.cloud.google.com: crear proyecto -> activar
# "Places API (New)" -> Credenciales -> Crear API key. Necesita
# facturación habilitada en el proyecto (hay crédito gratis mensual).
GOOGLE_PLACES_API_KEY=

# Secreto para que solo Vercel Cron pueda disparar la sincronización
# diaria (ver vercel.json). Cualquier string largo y random sirve —
# generalo por ejemplo con: openssl rand -hex 32
CRON_SECRET=

# OAuth de Google — opcional. Un mismo Client ID/Secret sirve para DOS
# cosas distintas dentro de Taply:
# a) Que cada CLIENTE conecte su propia cuenta de Google desde su portal
#    (/portal/[codigo]) y así automaticemos visitas, llamadas y clics
#    "cómo llegar" (Business Profile Performance API) de SU ficha.
# b) Que el EQUIPO inicie sesión en el panel con Google en vez de (o además
#    de) la contraseña compartida — así queda registrado quién hizo cada
#    cosa en /admin/actividad. Los emails permitidos se administran en
#    /admin/administradores (tabla `admins`), no acá.
#
# Setup:
# 1. Para (a): pedir acceso a las APIs de Business Profile (formulario de
#    Google, puede tardar días): https://developers.google.com/my-business/content/prereqs
#    y activar en el proyecto: Business Profile Performance API, My
#    Business Account Management API y My Business Business Information API.
#    Para (b) no hace falta nada de esto — el login de equipo solo usa
#    OpenID Connect estándar (openid email profile).
# 2. Pantalla de consentimiento OAuth (tipo Externo) con los scopes
#    https://www.googleapis.com/auth/business.manage, openid, email y
#    profile. Mientras la app esté en modo "Prueba" (sin verificar), los
#    tokens de Business Profile vencen a los 7 días — por eso el portal del
#    cliente muestra un aviso para reconectar cada semana. También hay que
#    sumar como "usuario de prueba" el email de Google de cada cliente que
#    vaya a conectar su ficha, o van a ver "acceso bloqueado".
# 3. Credenciales -> ID de cliente OAuth (Aplicación web) con estas DOS URI
#    de redireccionamiento (las dos van en el mismo cliente OAuth):
#      https://TU-DOMINIO.vercel.app/api/portal/google/oauth/callback
#      https://TU-DOMINIO.vercel.app/api/admin/oauth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Reviews API de Google Business Profile — listar y responder reseñas
# (lib/google-reviews.ts). Ya está todo el código escrito y esperando: esto
# necesita una aprobación de acceso APARTE de Google (mismo link de arriba,
# sección de reseñas) que todavía no tenemos. El día que llegue esa
# aprobación, poné GOOGLE_REVIEWS_API_ENABLED=true acá — no hace falta
# tocar código. Hasta entonces, dejalo vacío/false: el sync diario se salta
# esta parte en silencio y las reseñas se siguen gestionando a mano desde
# el portal del cliente, como siempre.
GOOGLE_REVIEWS_API_ENABLED=false

# Copiá este archivo a .env.local y completá tus valores reales.
